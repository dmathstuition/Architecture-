<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DMATHS Church Platform — Architecture & UI Preview</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;900&family=DM+Sans:wght@300;400;500;600&family=Cinzel:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #0B1F3A;
    --navy-mid: #12294F;
    --blue: #1A4480;
    --sky: #3A7BD5;
    --gold: #C8A84B;
    --gold-light: #E8C96A;
    --gold-pale: #FBF3DC;
    --white: #FFFFFF;
    --off-white: #F7F8FC;
    --gray-100: #EEF1F7;
    --gray-300: #B8C4D8;
    --gray-500: #7A8BAA;
    --gray-700: #3D4F6B;
    --success: #22C55E;
    --danger: #EF4444;
    --font-display: 'Playfair Display', Georgia, serif;
    --font-heading: 'Cinzel', serif;
    --font-body: 'DM Sans', sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  
  body {
    font-family: var(--font-body);
    background: var(--off-white);
    color: var(--navy);
    overflow-x: hidden;
  }

  /* ═══════════════════════════════════════════════
     NAVIGATION — TABS
  ═══════════════════════════════════════════════ */
  .tab-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--navy);
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0 24px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    border-bottom: 2px solid var(--gold);
  }

  .tab-nav .brand {
    font-family: var(--font-heading);
    color: var(--gold);
    font-size: 14px;
    letter-spacing: 2px;
    padding: 16px 0;
    margin-right: 32px;
    white-space: nowrap;
  }

  .tab-btn {
    background: none;
    border: none;
    color: var(--gray-300);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    padding: 18px 20px;
    cursor: pointer;
    border-bottom: 3px solid transparent;
    transition: all 0.25s ease;
    white-space: nowrap;
    letter-spacing: 0.5px;
  }
  .tab-btn:hover { color: var(--white); }
  .tab-btn.active {
    color: var(--gold-light);
    border-bottom-color: var(--gold);
    background: rgba(200,168,75,0.07);
  }

  .tab-panel { display: none; animation: fadeIn 0.35s ease; }
  .tab-panel.active { display: block; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══════════════════════════════════════════════
     SECTION LABELS
  ═══════════════════════════════════════════════ */
  .section-label {
    text-align: center;
    padding: 40px 24px 16px;
  }
  .section-label .eyebrow {
    font-family: var(--font-heading);
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--gold);
    margin-bottom: 8px;
    display: block;
  }
  .section-label h2 {
    font-family: var(--font-display);
    font-size: 28px;
    color: var(--navy);
  }
  .section-label p {
    color: var(--gray-500);
    font-size: 14px;
    margin-top: 6px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ═══════════════════════════════════════════════
     TAB 1 — ARCHITECTURE
  ═══════════════════════════════════════════════ */
  .arch-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px 48px;
  }
  @media(max-width:760px){ .arch-grid { grid-template-columns: 1fr; } }

  .arch-card {
    background: var(--white);
    border-radius: 16px;
    padding: 28px;
    border: 1px solid var(--gray-100);
    box-shadow: 0 2px 12px rgba(11,31,58,0.06);
    position: relative;
    overflow: hidden;
  }
  .arch-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--gold), var(--sky));
  }

  .arch-card .card-icon {
    width: 44px; height: 44px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
    margin-bottom: 16px;
  }
  .arch-card h3 {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--navy);
    margin-bottom: 12px;
  }
  .arch-card .tech-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--gray-100);
    color: var(--navy-mid);
    font-size: 12px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 20px;
    margin: 3px;
    letter-spacing: 0.3px;
  }
  .arch-card .tech-pill.gold { background: var(--gold-pale); color: #8B6914; }
  .arch-card .tech-pill.blue { background: #E0EAFB; color: var(--blue); }
  .arch-card p { font-size: 13px; color: var(--gray-500); line-height: 1.7; margin-bottom: 14px; }

  .flow-diagram {
    background: var(--navy);
    border-radius: 16px;
    padding: 32px;
    grid-column: 1 / -1;
    color: var(--white);
  }
  .flow-diagram h3 {
    font-family: var(--font-display);
    font-size: 20px;
    color: var(--gold-light);
    margin-bottom: 24px;
    text-align: center;
  }
  .flow-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .flow-box {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(200,168,75,0.3);
    border-radius: 10px;
    padding: 12px 18px;
    font-size: 12px;
    font-weight: 600;
    text-align: center;
    color: var(--white);
    min-width: 110px;
  }
  .flow-box.highlight {
    background: rgba(200,168,75,0.15);
    border-color: var(--gold);
    color: var(--gold-light);
  }
  .flow-arrow {
    color: var(--gold);
    font-size: 18px;
    font-weight: bold;
  }

  /* ═══════════════════════════════════════════════
     TAB 2 — HOMEPAGE UI
  ═══════════════════════════════════════════════ */
  .browser-chrome {
    background: #1A1E2A;
    border-radius: 12px;
    overflow: hidden;
    max-width: 1000px;
    margin: 0 auto 32px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.25);
  }
  .browser-bar {
    background: #252B3B;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .browser-dots { display: flex; gap: 6px; }
  .browser-dots span { width: 10px; height: 10px; border-radius: 50%; }
  .browser-dots span:nth-child(1) { background: #FF5F57; }
  .browser-dots span:nth-child(2) { background: #FFBD2E; }
  .browser-dots span:nth-child(3) { background: #28C840; }
  .browser-url {
    flex: 1;
    background: #1A1E2A;
    border-radius: 6px;
    padding: 5px 12px;
    font-size: 11px;
    color: var(--gray-300);
    font-family: monospace;
  }

  /* HOMEPAGE MOCK */
  .site-nav-mock {
    background: rgba(11,31,58,0.95);
    backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 28px;
    position: relative;
    z-index: 10;
  }
  .site-logo { font-family: var(--font-heading); font-size: 15px; color: var(--gold); letter-spacing: 2px; }
  .site-nav-links { display: flex; gap: 20px; }
  .site-nav-links a { font-size: 12px; color: var(--gray-300); text-decoration: none; font-weight: 500; }
  .site-nav-links a.active { color: var(--gold-light); }
  .donate-btn {
    background: var(--gold);
    color: var(--navy);
    font-size: 11px;
    font-weight: 700;
    padding: 7px 16px;
    border-radius: 20px;
    letter-spacing: 0.5px;
  }

  .hero-mock {
    background: linear-gradient(135deg, var(--navy) 0%, #1a3a6b 50%, #0d2440 100%);
    min-height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 40px 28px;
  }
  .hero-mock::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 50%, rgba(200,168,75,0.12) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 80%, rgba(58,123,213,0.15) 0%, transparent 50%);
  }
  .hero-cross {
    position: absolute;
    right: 40px;
    top: 50%;
    transform: translateY(-50%);
    opacity: 0.07;
    font-size: 180px;
    color: var(--white);
    pointer-events: none;
    line-height: 1;
  }
  .hero-content { position: relative; z-index: 2; text-align: center; }
  .hero-eyebrow {
    font-family: var(--font-heading);
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--gold);
    margin-bottom: 12px;
    display: block;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: 36px;
    color: var(--white);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 12px;
  }
  .hero-title em { color: var(--gold-light); font-style: normal; }
  .hero-sub { font-size: 13px; color: rgba(255,255,255,0.65); margin-bottom: 24px; max-width: 400px; line-height: 1.7; }
  .hero-buttons { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
  .btn-primary {
    background: var(--gold);
    color: var(--navy);
    font-size: 12px;
    font-weight: 700;
    padding: 10px 22px;
    border-radius: 4px;
    letter-spacing: 0.5px;
  }
  .btn-outline {
    border: 1.5px solid rgba(255,255,255,0.3);
    color: var(--white);
    font-size: 12px;
    font-weight: 500;
    padding: 9px 22px;
    border-radius: 4px;
  }
  .btn-live {
    background: #EF4444;
    color: var(--white);
    font-size: 11px;
    font-weight: 700;
    padding: 10px 18px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .live-dot { width: 7px; height: 7px; background: white; border-radius: 50%; animation: pulse 1.2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

  .section-strip {
    background: var(--white);
    padding: 20px 28px;
  }
  .strip-title {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--navy);
    margin-bottom: 16px;
  }
  .strip-title span { color: var(--gold); }

  .sermon-cards-row { display: flex; gap: 12px; overflow-x: auto; padding-bottom: 8px; }
  .sermon-card-mock {
    background: var(--off-white);
    border-radius: 10px;
    overflow: hidden;
    min-width: 170px;
    flex-shrink: 0;
    border: 1px solid var(--gray-100);
  }
  .sermon-thumb {
    background: linear-gradient(135deg, #1A4480, #0B1F3A);
    height: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .play-icon {
    width: 32px; height: 32px;
    background: rgba(200,168,75,0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    color: var(--navy);
    font-weight: bold;
  }
  .sermon-badge {
    position: absolute;
    top: 8px; right: 8px;
    background: var(--gold);
    color: var(--navy);
    font-size: 9px;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 10px;
    letter-spacing: 0.5px;
  }
  .sermon-info { padding: 10px 12px; }
  .sermon-title-mock { font-size: 11px; font-weight: 600; color: var(--navy); margin-bottom: 4px; }
  .sermon-meta-mock { font-size: 10px; color: var(--gray-500); }

  .events-row { display: flex; gap: 12px; overflow-x: auto; padding-bottom: 8px; }
  .event-card-mock {
    background: var(--navy);
    border-radius: 10px;
    padding: 16px;
    min-width: 160px;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
  }
  .event-card-mock::before {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 3px; height: 100%;
    background: var(--gold);
  }
  .event-date { font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--gold); line-height: 1; }
  .event-month { font-size: 10px; color: var(--gray-300); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 8px; }
  .event-name { font-size: 12px; font-weight: 600; color: var(--white); margin-bottom: 4px; }
  .event-time { font-size: 10px; color: var(--gray-500); }

  /* ═══════════════════════════════════════════════
     TAB 3 — ADMIN DASHBOARD
  ═══════════════════════════════════════════════ */
  .dashboard-wrapper {
    display: grid;
    grid-template-columns: 220px 1fr;
    height: 560px;
    background: var(--white);
    border-radius: 12px;
    overflow: hidden;
    max-width: 1000px;
    margin: 0 auto;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  }
  @media(max-width:700px){ .dashboard-wrapper { grid-template-columns: 1fr; height: auto; } }

  .dash-sidebar {
    background: var(--navy);
    padding: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .dash-logo {
    padding: 20px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    font-family: var(--font-heading);
    font-size: 12px;
    color: var(--gold);
    letter-spacing: 2px;
  }
  .dash-logo small { display: block; font-size: 9px; color: var(--gray-500); letter-spacing: 1px; margin-top: 2px; }

  .dash-menu { padding: 16px 0; flex: 1; overflow-y: auto; }
  .dash-section { font-size: 9px; color: var(--gray-500); letter-spacing: 2px; padding: 8px 20px 4px; text-transform: uppercase; }
  .dash-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 20px;
    font-size: 12px;
    color: var(--gray-300);
    cursor: pointer;
    transition: all 0.2s;
    font-weight: 500;
  }
  .dash-link:hover { background: rgba(255,255,255,0.05); color: var(--white); }
  .dash-link.active {
    background: rgba(200,168,75,0.12);
    color: var(--gold-light);
    border-right: 3px solid var(--gold);
  }
  .dash-link .icon { font-size: 14px; width: 18px; text-align: center; }
  .dash-link .badge {
    margin-left: auto;
    background: var(--gold);
    color: var(--navy);
    font-size: 9px;
    font-weight: 700;
    padding: 1px 7px;
    border-radius: 10px;
  }

  .dash-main {
    background: var(--off-white);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .dash-topbar {
    background: var(--white);
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--gray-100);
  }
  .topbar-left h2 { font-size: 15px; font-weight: 600; color: var(--navy); }
  .topbar-left p { font-size: 11px; color: var(--gray-500); margin-top: 1px; }
  .topbar-right { display: flex; align-items: center; gap: 12px; }
  .topbar-btn {
    background: var(--gold);
    color: var(--navy);
    font-size: 11px;
    font-weight: 700;
    padding: 7px 14px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--sky), var(--navy));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 12px;
    font-weight: 700;
  }

  .dash-content {
    padding: 20px 24px;
    overflow-y: auto;
    flex: 1;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    margin-bottom: 20px;
  }
  @media(max-width:600px){ .stats-row { grid-template-columns: 1fr 1fr; } }

  .stat-card {
    background: var(--white);
    border-radius: 10px;
    padding: 16px;
    border: 1px solid var(--gray-100);
    position: relative;
    overflow: hidden;
  }
  .stat-card::after {
    content: attr(data-icon);
    position: absolute;
    right: 10px;
    top: 10px;
    font-size: 22px;
    opacity: 0.15;
  }
  .stat-label { font-size: 10px; color: var(--gray-500); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; }
  .stat-value { font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--navy); }
  .stat-change { font-size: 10px; margin-top: 3px; }
  .stat-change.up { color: var(--success); }
  .stat-change.down { color: var(--danger); }

  .dash-two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  @media(max-width:600px){ .dash-two-col { grid-template-columns: 1fr; } }

  .dash-widget {
    background: var(--white);
    border-radius: 10px;
    padding: 16px;
    border: 1px solid var(--gray-100);
  }
  .widget-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }
  .widget-title { font-size: 13px; font-weight: 600; color: var(--navy); }
  .widget-action { font-size: 11px; color: var(--sky); cursor: pointer; }

  .sermon-row-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid var(--gray-100);
  }
  .sermon-row-item:last-child { border-bottom: none; }
  .sermon-thumb-mini {
    width: 40px; height: 30px;
    background: linear-gradient(135deg, var(--sky), var(--navy));
    border-radius: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: white;
    flex-shrink: 0;
  }
  .sermon-row-info { flex: 1; overflow: hidden; }
  .sermon-row-title { font-size: 11px; font-weight: 600; color: var(--navy); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .sermon-row-meta { font-size: 10px; color: var(--gray-500); }
  .sermon-row-views { font-size: 10px; color: var(--gray-500); white-space: nowrap; }

  /* Chart bars */
  .chart-bars {
    display: flex;
    align-items: flex-end;
    gap: 6px;
    height: 80px;
    padding-bottom: 4px;
    border-bottom: 1px solid var(--gray-100);
    margin-bottom: 8px;
  }
  .bar-group { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px; }
  .bar {
    width: 100%;
    border-radius: 3px 3px 0 0;
    background: linear-gradient(180deg, var(--sky), var(--blue));
    transition: height 0.3s;
    cursor: pointer;
    position: relative;
  }
  .bar.gold-bar { background: linear-gradient(180deg, var(--gold-light), var(--gold)); }
  .bar:hover::after {
    content: attr(data-val);
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--navy);
    color: white;
    font-size: 9px;
    padding: 2px 5px;
    border-radius: 3px;
    white-space: nowrap;
  }
  .bar-label { font-size: 9px; color: var(--gray-500); }

  /* Donation item */
  .donation-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid var(--gray-100);
    font-size: 11px;
  }
  .donation-item:last-child { border-bottom: none; }
  .donation-left { display: flex; align-items: center; gap: 8px; }
  .donor-avatar {
    width: 26px; height: 26px;
    border-radius: 50%;
    font-size: 10px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    flex-shrink: 0;
  }
  .donation-amount { font-weight: 700; color: var(--success); }
  .donation-name { color: var(--navy); font-weight: 500; }
  .donation-time { font-size: 10px; color: var(--gray-500); }

  /* ═══════════════════════════════════════════════
     TAB 4 — FOLDER STRUCTURE
  ═══════════════════════════════════════════════ */
  .folder-tree {
    background: #0D1117;
    border-radius: 12px;
    padding: 28px 32px;
    max-width: 800px;
    margin: 0 auto 32px;
    font-family: 'Courier New', monospace;
    font-size: 13px;
    line-height: 1.9;
    color: #C9D1D9;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  }
  .ft-dir { color: #79C0FF; font-weight: bold; }
  .ft-file { color: #C9D1D9; }
  .ft-comment { color: #6A737D; }
  .ft-special { color: #FFA657; }
  .ft-green { color: #56D364; }

  .install-block {
    background: #0D1117;
    border-radius: 12px;
    padding: 24px 28px;
    max-width: 800px;
    margin: 0 auto 24px;
    font-family: 'Courier New', monospace;
